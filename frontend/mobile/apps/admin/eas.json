{
    "cli":  {
                "version":  "\u003e= 12.0.0",
                "appVersionSource":  "remote"
            },
    "build":  {
                  "development":  {
                                      "developmentClient":  true,
                                      "distribution":  "internal",
                                      "channel":  "development",
                                      "env":  {
                                                  "APP_ENV":  "development",
                                                  "SENTRY_ALLOW_FAILURE":  "true"
                                              }
                                  },
                  "preview":  {
                                  "distribution":  "internal",
                                  "channel":  "preview",
                                  "env":  {
                                              "APP_ENV":  "preview",
                                              "SENTRY_ALLOW_FAILURE":  "true"
                                          }
                              },
                  "production":  {
                                     "distribution":  "store",
                                     "channel":  "production",
                                     "env":  {
                                                 "APP_ENV":  "production",
                                                 "SENTRY_ALLOW_FAILURE":  "true"
                                             }
                                 }
              },
    "submit":  {
                   "production":  {

                                  }
               }
}
